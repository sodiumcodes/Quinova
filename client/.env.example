# Local development: leave this relative so Vite proxies /api to the backend.
VITE_API_BASE_URL=/api/v1

# Local development backend URL used by client/vite.config.js.
VITE_API_PROXY_TARGET=http://localhost:3000

# Production separate deploy example:
# VITE_API_BASE_URL=https://your-backend-domain.com/api/v1
