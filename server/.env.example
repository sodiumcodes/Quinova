PORT=3000
MONGO_URI=mongodb+srv://<username>:<password>@<cluster>/<database>

# Vite dev server is HTTP by default. Use https://localhost:5173 only if you explicitly enabled HTTPS in Vite.
# Add multiple origins as a comma-separated list when needed.
CORS_ORIGIN=http://localhost:5173

ACCESS_TOKEN_SECRET=replace-with-a-long-random-secret
ACCESS_TOKEN_EXPIRY=1d
REFRESH_TOKEN_SECRET=replace-with-a-long-random-secret
REFRESH_TOKEN_EXPIRY=5d

IMAGEKIT_PUBLIC_KEY=replace-me
IMAGEKIT_PRIVATE_KEY=replace-me
IMAGEKIT_URL_ENDPOINT=https://ik.imagekit.io/your_id
